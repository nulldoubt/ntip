# Install this file inside NGINX's `http {}` context (for example under
# /etc/nginx/conf.d), then replace the listen address, server_name, and TLS
# paths. Do not configure real_ip/forwarded-address trust for these routes:
# the socket peer is the admission-control identity.
limit_req_zone $binary_remote_addr zone=ntip_enrollment_redeem:1m rate=10r/m;

server {
    listen 127.0.0.1:443 ssl;
    server_name ntip.example.invalid;

    ssl_certificate /etc/nginx/ntip/ntip.crt;
    ssl_certificate_key /etc/nginx/ntip/ntip.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_tickets off;

    client_max_body_size 64k;

    # Anonymous redemption is the only rate-limited public POST. Its body can
    # contain the short code, so neither this location nor its local error
    # handlers write access-log records. NGINX's error log never includes the
    # request body under this configuration.
    location = /enrollment/v1/redeem {
        if ($request_method != POST) { return 405; }
        if ($http_content_length = "") { return 400; }
        if ($http_transfer_encoding != "") { return 400; }
        if ($http_content_type != "application/json") { return 415; }
        if ($http_origin != "") { return 400; }

        client_max_body_size 128;
        client_body_buffer_size 128;
        client_body_timeout 10s;

        limit_req zone=ntip_enrollment_redeem burst=5 nodelay;
        limit_req_status 429;
        limit_req_log_level notice;

        error_page 400 = @ntip_bootstrap_bad_request;
        error_page 405 = @ntip_bootstrap_post_only;
        error_page 413 = @ntip_bootstrap_too_large;
        error_page 415 = @ntip_bootstrap_unsupported_media;
        error_page 429 = @ntip_bootstrap_rate_limited;

        access_log off;
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        # ntip-api uses bounded connection-owning workers. Close every trusted
        # loopback hop after its response so an idle upstream socket cannot
        # retain an admission slot.
        proxy_set_header Connection close;
        proxy_set_header Expect "";
        proxy_set_header Cookie "";
        proxy_set_header Authorization "";
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For "";
        proxy_set_header X-Forwarded-Proto "";
        proxy_set_header X-Real-IP "";
        proxy_request_buffering off;
        proxy_buffering off;
        proxy_cache off;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        proxy_max_temp_file_size 0;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 30s;
        proxy_hide_header Set-Cookie;
    }

    # Only basenames emitted by the bootstrap-assets package are reachable.
    # Root-owned 0644 immutable assets may be read by NGINX but never changed
    # by its worker identity.
    location ~ "^/enrollment/assets/(ntip-node-v[A-Za-z0-9][A-Za-z0-9.+-]{0,63}-(?:x86_64|aarch64)-linux-musl(?:[.]tar[.]gz(?:[.]sha256)?|[.]spdx[.]json))$" {
        if ($request_method != GET) { return 405; }

        alias /usr/share/ntip/bootstrap-assets/$1;
        disable_symlinks on from=/usr/share/ntip/bootstrap-assets;
        default_type application/octet-stream;
        sendfile on;
        etag on;
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header X-Content-Type-Options "nosniff";
        error_page 404 = @ntip_bootstrap_asset_not_found;
        error_page 405 = @ntip_bootstrap_get_only;
    }

    # The public locator is not a secret and may remain in the ordinary access
    # log. Cookies and authorization headers are stripped before the request
    # reaches the cookie-independent API route.
    location ~ "^/enrollment/[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{8}$" {
        if ($request_method != GET) { return 405; }
        if ($http_content_length != "") { return 400; }
        if ($http_transfer_encoding != "") { return 400; }

        error_page 400 = @ntip_bootstrap_bad_request;
        error_page 405 = @ntip_bootstrap_get_only;

        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Connection close;
        proxy_set_header Content-Length "";
        proxy_set_header Cookie "";
        proxy_set_header Authorization "";
        proxy_set_header Origin "";
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For "";
        proxy_set_header X-Forwarded-Proto "";
        proxy_set_header X-Real-IP "";
        proxy_pass_request_body off;
        proxy_buffering off;
        proxy_cache off;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        proxy_max_temp_file_size 0;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 30s;
        proxy_hide_header Set-Cookie;
    }

    # Prevent malformed or unversioned enrollment paths from falling through
    # to the dashboard service.
    location /enrollment/assets/ {
        error_page 404 = @ntip_bootstrap_asset_not_found;
        return 404;
    }

    location /enrollment/ {
        error_page 404 = @ntip_bootstrap_unavailable;
        return 404;
    }

    location @ntip_bootstrap_bad_request {
        internal;
        access_log off;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 400 '{"error":{"code":"invalid_request","message":"Bootstrap request is invalid."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_get_only {
        internal;
        access_log off;
        default_type application/json;
        add_header Allow "GET" always;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 405 '{"error":{"code":"invalid_request","message":"Bootstrap request method is not allowed."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_post_only {
        internal;
        access_log off;
        default_type application/json;
        add_header Allow "POST" always;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 405 '{"error":{"code":"invalid_request","message":"Bootstrap request method is not allowed."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_too_large {
        internal;
        access_log off;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 413 '{"error":{"code":"invalid_request","message":"Bootstrap request body is too large."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_unsupported_media {
        internal;
        access_log off;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 415 '{"error":{"code":"invalid_request","message":"Bootstrap request must use application/json."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_rate_limited {
        internal;
        access_log off;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        add_header Retry-After "60" always;
        return 429 '{"error":{"code":"rate_limited","message":"Bootstrap redemption is temporarily rate limited."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_unavailable {
        internal;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Request-ID $request_id always;
        return 404 '{"error":{"code":"bootstrap_unavailable","message":"Bootstrap invitation is unavailable."},"requestId":"$request_id"}';
    }

    location @ntip_bootstrap_asset_not_found {
        internal;
        default_type application/octet-stream;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        return 404;
    }

    # Existing authenticated management API proxy. Keep this route and the
    # dashboard route unchanged when merging enrollment support.
    location ^~ /api/v1/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Connection close;
        proxy_buffering off;
        proxy_read_timeout 65s;
        proxy_send_timeout 65s;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_read_timeout 65s;
        proxy_send_timeout 65s;
    }
}
